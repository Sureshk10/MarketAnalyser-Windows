<Window x:Class="MarketAnalyser.App.TradingViewChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="TradingView Chart"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Background="#0B1118">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#111A24" Padding="14,10">
            <DockPanel LastChildFill="False">
                <StackPanel>
                    <TextBlock x:Name="TitleText" Foreground="White" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="TradingView candles with VWAP, Supertrend, EMA, RSI and MACD"
                               Foreground="#8B9CB0"
                               FontSize="12" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Interval" Foreground="#8B9CB0" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox x:Name="IntervalCombo"
                              Width="92"
                              SelectedIndex="0"
                              SelectionChanged="IntervalCombo_SelectionChanged">
                        <ComboBoxItem Content="1m" Tag="1" />
                        <ComboBoxItem Content="2m" Tag="2" />
                        <ComboBoxItem Content="3m" Tag="3" />
                        <ComboBoxItem Content="5m" Tag="5" />
                        <ComboBoxItem Content="15m" Tag="15" />
                        <ComboBoxItem Content="30m" Tag="30" />
                        <ComboBoxItem Content="1h" Tag="60" />
                        <ComboBoxItem Content="1D" Tag="D" />
                    </ComboBox>
                    <Button Content="Reload" Margin="10,0,0,0" Padding="12,3" Click="ReloadButton_Click" />
                </StackPanel>
            </DockPanel>
        </Border>
        <wv2:WebView2 x:Name="ChartWebView" />
    </DockPanel>
</Window>
