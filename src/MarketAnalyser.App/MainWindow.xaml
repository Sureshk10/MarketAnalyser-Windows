<Window x:Class="MarketAnalyser.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MarketAnalyser.App.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Market Analyser"
        Width="1380"
        Height="820"
        MinWidth="1120"
        MinHeight="680"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="MetricText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D8E1EC" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#101720" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="Foreground" Value="#D8E1EC" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#101720" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="Foreground" Value="#D8E1EC" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#101720" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="Foreground" Value="#D8E1EC" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#101720" />
            <Setter Property="Foreground" Value="#D8E1EC" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              ContentStringFormat="{TemplateBinding ContentStringFormat}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1D2A38" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#203140" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6F7F91" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTimeComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="0"
                                          Foreground="{TemplateBinding Foreground}"
                                          Padding="{TemplateBinding Padding}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ToggleBorder"
                                                Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="22" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Margin="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                                           Text="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}, StringFormat={}{0:00}}" />
                                                <Path Grid.Column="1"
                                                      Width="8"
                                                      Height="4"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Fill="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                                      Data="M 0 0 L 4 4 L 8 0 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#4A5B70" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="#172231" />
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#4A5B70" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.55" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   PlacementTarget="{Binding ElementName=ToggleButton}"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   StaysOpen="False">
                                <Border Background="#101720"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <ScrollViewer CanContentScroll="True"
                                                  VerticalScrollBarVisibility="Auto"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="Black" />
            <Setter Property="Foreground" Value="#D8E1EC" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style TargetType="DatePickerTextBox">
            <Setter Property="Background" Value="Black" />
            <Setter Property="Foreground" Value="#D8E1EC" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="Padding" Value="2" />
        </Style>

        <Style TargetType="Calendar">
            <Setter Property="Background" Value="#101720" />
            <Setter Property="Foreground" Value="#D8E1EC" />
        </Style>

        <Style TargetType="CalendarDayButton">
            <Setter Property="Background" Value="#101720" />
            <Setter Property="Foreground" Value="#D8E1EC" />
        </Style>

        <Style x:Key="StarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#F6C85F" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SmallChromeButton" TargetType="Button">
            <Setter Property="Background" Value="#172231" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="Foreground" Value="#D8E1EC" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#101720" />
            <Setter Property="Foreground" Value="#D8E1EC" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="RowBackground" Value="#101720" />
            <Setter Property="AlternatingRowBackground" Value="#121C27" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#263241" />
            <Setter Property="VerticalGridLinesBrush" Value="#263241" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="AutoGenerateColumns" Value="False" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2532" />
            <Setter Property="Foreground" Value="#AFC1D4" />
            <Setter Property="BorderBrush" Value="#263241" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Foreground" Value="#D8E1EC" />
        </Style>

        <Style x:Key="OptionRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{Binding RowBackground}" />
            <Setter Property="Foreground" Value="#D8E1EC" />
            <Setter Property="MinHeight" Value="30" />
        </Style>

        <Style x:Key="RightAlignedCellText" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="StrikeCellText" TargetType="TextBlock" BasedOn="{StaticResource RightAlignedCellText}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="StrikeCellButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="OrderActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#111A24" />
            <Setter Property="BorderBrush" Value="#2A3644" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#D8E1EC" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="CompactActionCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="CallOiCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="{Binding CallOiBackground}" />
            <Setter Property="BorderBrush" Value="#263241" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style x:Key="PutOiCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="{Binding PutOiBackground}" />
            <Setter Property="BorderBrush" Value="#263241" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style x:Key="CallOiChangeCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="{Binding CallOiChangeBackground}" />
            <Setter Property="BorderBrush" Value="#263241" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style x:Key="PutOiChangeCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="{Binding PutOiChangeBackground}" />
            <Setter Property="BorderBrush" Value="#263241" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style x:Key="CallOiChangeText" TargetType="TextBlock" BasedOn="{StaticResource RightAlignedCellText}">
            <Setter Property="Foreground" Value="{Binding CallOiChangeForeground}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="PutOiChangeText" TargetType="TextBlock" BasedOn="{StaticResource RightAlignedCellText}">
            <Setter Property="Foreground" Value="{Binding PutOiChangeForeground}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="PressureText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{Binding PressureForeground}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding LeftPanelColumnWidth}" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="{Binding RightPanelColumnWidth}" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource PanelStyle}" Margin="0,0,14,0" Visibility="{Binding LeftPanelVisibility}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <TextBlock Text="Market Analyser" FontSize="22" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="NIFT-AI workspace" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                    <TextBox Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,16,0,0"
                             ToolTip="Search symbol or name" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                    <TextBlock Text="Feed" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Text="{Binding DataSourceName}" FontWeight="SemiBold" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Foreground="{StaticResource AccentBrush}" Margin="0,10,0,0" />
                </StackPanel>

                <ListBox ItemsSource="{Binding FilteredInstruments}"
                         SelectedItem="{Binding SelectedInstrument, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Style="{StaticResource StarButton}"
                                        Content="{Binding FavoriteGlyph}"
                                        Focusable="False"
                                        Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Toggle favorite" />
                                <Grid Grid.Column="1" Margin="8,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Foreground="{StaticResource MutedTextBrush}" FontSize="12">
                                        <Run Text="{Binding Symbol, Mode=OneWay}" />
                                        <Run Text=" · " />
                                        <Run Text="{Binding SegmentLabel, Mode=OneWay}" />
                                    </TextBlock>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="{Binding AlertsRowHeight}" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="{Binding SymbolTitle}" FontSize="30" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="Option-chain movement, OI pressure, IV/Greeks, support and resistance." Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Text="{Binding SessionStatus}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                </StackPanel>
                    <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <WrapPanel HorizontalAlignment="Right" Margin="0,0,0,8">
                            <Button Style="{StaticResource SmallChromeButton}"
                                Content="{Binding LeftPanelToggleText}"
                                Command="{Binding ToggleLeftPanelCommand}" />
                            <Button Style="{StaticResource SmallChromeButton}"
                                Content="{Binding AlertsPanelToggleText}"
                                Command="{Binding ToggleAlertsPanelCommand}" />
                        <Button Style="{StaticResource SmallChromeButton}"
                                Content="{Binding RightPanelToggleText}"
                                Command="{Binding ToggleRightPanelCommand}" />
                        <Button Style="{StaticResource SmallChromeButton}"
                                Content="{Binding SessionReviewPanelToggleText}"
                                Command="{Binding ToggleSessionReviewPanelCommand}" />
                            <Button Style="{StaticResource SmallChromeButton}"
                                Content="Orders"
                                Command="{Binding OpenOrdersPopupCommand}" />
                        </WrapPanel>
                        <TextBlock Text="Last update" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding LastUpdatedText}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right" />
                    </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource PanelStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Spot" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Text="{Binding SpotText}" Style="{StaticResource MetricText}" />
                        <TextBlock Text="{Binding SpotChangeText}" Foreground="{Binding SpotChangeForeground}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource PanelStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="PCR OI" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Text="{Binding PcrOiText}" Style="{StaticResource MetricText}" />
                        <TextBlock Text="Put OI / Call OI" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource PanelStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="PCR Volume" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Text="{Binding PcrVolumeText}" Style="{StaticResource MetricText}" />
                        <TextBlock Text="Put volume / Call volume" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3"
                        Grid.ColumnSpan="2"
                        Style="{StaticResource PanelStyle}"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Signal" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Text="{Binding MarketSignalText}" Style="{StaticResource MetricText}" Foreground="{Binding MarketSignalForeground}" FontSize="20" />
                        <TextBlock Text="{Binding MarketSignalDetail}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" FontSize="11" />
                        <TextBlock Text="{Binding MarketDepthInfluenceText}" Foreground="{Binding MarketDepthInfluenceForeground}" TextWrapping="Wrap" FontSize="11" FontWeight="SemiBold" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource PanelStyle}" Margin="0,0,0,14" Visibility="{Binding AlertsPanelVisibility}">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Alerts" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <CheckBox IsChecked="{Binding AlertsEnabled}" Content="Enabled" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <Button Content="Clear" Command="{Binding ClearAlertsCommand}" Padding="10,2" />
                        </StackPanel>
                    </Grid>
                    <UniformGrid DockPanel.Dock="Top" Columns="3" Margin="0,0,0,8">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="OI threshold" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                            <TextBox Text="{Binding OiBuildupThreshold, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Near S/R pts" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                            <TextBox Text="{Binding SupportResistanceProximityPoints, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Cooldown sec" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                            <TextBox Text="{Binding AlertCooldownSeconds, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>
                    </UniformGrid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <DockPanel Margin="0,0,10,0">
                            <TextBlock DockPanel.Dock="Top" Text="Alerts" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,4" />
                            <ListBox ItemsSource="{Binding Alerts}" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="58" />
                                                <ColumnDefinition Width="104" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TimeText}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                            <TextBlock Grid.Column="1" Text="{Binding Title}" Foreground="{Binding Foreground}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="#D8E1EC" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                        <DockPanel Grid.Column="1">
                            <TextBlock DockPanel.Dock="Top" Text="Movement Timeline" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,4" />
                            <ListBox ItemsSource="{Binding MovementTimeline}" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="58" />
                                                <ColumnDefinition Width="135" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TimeText}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Title}" Foreground="{Binding Foreground}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding SpotText}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding Detail}" Foreground="#D8E1EC" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding WatchText}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource PanelStyle}">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="Live Option Chain" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,12" />
                    <DataGrid ItemsSource="{Binding StrikeRows}"
                              SelectedItem="{Binding SelectedStrikeRow, Mode=TwoWay}"
                              SelectionChanged="StrikeRowsGrid_SelectionChanged"
                              RowStyle="{StaticResource OptionRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding AtmLabel}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="CE" Width="Auto" CellStyle="{StaticResource CompactActionCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="B"
                                                    Foreground="MediumSeaGreen"
                                                    Style="{StaticResource OrderActionButtonStyle}"
                                                    Margin="0,0,4,0"
                                                    Command="{Binding DataContext.OpenStrikeOrderScreenCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="CE Buy" />
                                            <Button Content="S"
                                                    Foreground="IndianRed"
                                                    Style="{StaticResource OrderActionButtonStyle}"
                                                    Command="{Binding DataContext.OpenStrikeOrderScreenCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="CE Sell" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="CE IV" Binding="{Binding Snapshot.Call.ImpliedVolatility, StringFormat=N2}" ElementStyle="{StaticResource RightAlignedCellText}" Width="0.9*" />
                            <DataGridTextColumn Header="CE OI" Binding="{Binding CallOpenInterestText}" CellStyle="{StaticResource CallOiCell}" ElementStyle="{StaticResource RightAlignedCellText}" Width="1.1*" />
                            <DataGridTextColumn Header="CE Vol" Binding="{Binding CallVolumeText}" ElementStyle="{StaticResource RightAlignedCellText}" Width="0.9*" />
                            <DataGridTextColumn Header="CE OI Chg" Binding="{Binding CallOpenInterestChangeText}" CellStyle="{StaticResource CallOiChangeCell}" ElementStyle="{StaticResource CallOiChangeText}" Width="1.1*" />
                            <DataGridTextColumn Header="CE LTP" Binding="{Binding Snapshot.Call.LastPrice, StringFormat=N2}" ElementStyle="{StaticResource RightAlignedCellText}" Width="0.9*" />
                            <DataGridTemplateColumn Header="Strike" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Strike, StringFormat=N0}"
                                                Command="{Binding DataContext.ShowStrikeDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding Snapshot}"
                                                Style="{StaticResource StrikeCellButtonStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="PE LTP" Binding="{Binding Snapshot.Put.LastPrice, StringFormat=N2}" ElementStyle="{StaticResource RightAlignedCellText}" Width="0.9*" />
                            <DataGridTextColumn Header="PE OI Chg" Binding="{Binding PutOpenInterestChangeText}" CellStyle="{StaticResource PutOiChangeCell}" ElementStyle="{StaticResource PutOiChangeText}" Width="1.1*" />
                            <DataGridTextColumn Header="PE Vol" Binding="{Binding PutVolumeText}" ElementStyle="{StaticResource RightAlignedCellText}" Width="0.9*" />
                            <DataGridTextColumn Header="PE OI" Binding="{Binding PutOpenInterestText}" CellStyle="{StaticResource PutOiCell}" ElementStyle="{StaticResource RightAlignedCellText}" Width="1.1*" />
                            <DataGridTextColumn Header="PE IV" Binding="{Binding Snapshot.Put.ImpliedVolatility, StringFormat=N2}" ElementStyle="{StaticResource RightAlignedCellText}" Width="0.9*" />
                            <DataGridTemplateColumn Header="PE" Width="Auto" CellStyle="{StaticResource CompactActionCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="B"
                                                    Foreground="MediumSeaGreen"
                                                    Style="{StaticResource OrderActionButtonStyle}"
                                                    Margin="0,0,4,0"
                                                    Command="{Binding DataContext.OpenStrikeOrderScreenCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="PE Buy" />
                                            <Button Content="S"
                                                    Foreground="IndianRed"
                                                    Style="{StaticResource OrderActionButtonStyle}"
                                                    Command="{Binding DataContext.OpenStrikeOrderScreenCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="PE Sell" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Pressure" Binding="{Binding PressureLabel}" ElementStyle="{StaticResource PressureText}" Width="1*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <Grid Grid.Column="2" Margin="14,0,0,0" Visibility="{Binding RightPanelVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="200" />
                <RowDefinition Height="130" />
                <RowDefinition Height="{Binding SessionReviewRowHeight}" />
                <RowDefinition Height="{Binding LiveScanRowHeight}" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PanelStyle}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Price Action" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                    <controls:LineChartControl Height="118"
                                                Margin="0,12,0,0"
                                                Cursor="Hand"
                                                ToolTip="Open TradingView candle chart"
                                                Series="{Binding PriceChartSeries}">
                        <controls:LineChartControl.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding OpenTradingViewChartCommand}" />
                        </controls:LineChartControl.InputBindings>
                    </controls:LineChartControl>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <StackPanel Margin="0,0,10,8">
                            <TextBlock Text="From open" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                            <TextBlock Text="{Binding SessionOpenMoveText}" Foreground="{Binding SessionTrendForeground}" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,0,8">
                            <TextBlock Text="Range" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                            <TextBlock Text="{Binding SessionRangeText}" Foreground="White" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Margin="0,0,10,0">
                            <TextBlock Text="Trend" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                            <TextBlock Text="{Binding SessionTrendText}" Foreground="{Binding SessionTrendForeground}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1">
                            <TextBlock Text="OI shift" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                            <TextBlock Text="{Binding SessionOiShiftText}" Foreground="{Binding SessionOiShiftForeground}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource PanelStyle}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Movement Reading" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="{Binding MovementReadingTitle}" FontSize="20" FontWeight="SemiBold" Foreground="{Binding MovementReadingForeground}" Margin="0,12,0,4" />
                    <TextBlock Text="{Binding MovementReadingDetail}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Text="{Binding MovementReadingWatchText}" TextWrapping="Wrap" Foreground="White" FontWeight="SemiBold" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource PanelStyle}" Margin="0,0,0,14" Visibility="{Binding SessionReviewVisibility}">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Session Review" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="{Binding LiveModeText}" Foreground="{StaticResource MutedTextBrush}" Margin="8,4,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Export" Command="{Binding ExportSessionReviewCommand}" Padding="10,2" />
                    </Grid>
                    <StackPanel>
                        <WrapPanel Margin="0,0,0,8" VerticalAlignment="Top">
                            <DatePicker SelectedDate="{Binding ReplaySelectedDate, Mode=TwoWay}"
                                        Width="124"
                                        Margin="0,0,6,6"
                                        Background="Black"
                                        Foreground="White" />
                            <ComboBox ItemsSource="{Binding ReplayHourOptions}"
                                      SelectedItem="{Binding ReplaySelectedHour, Mode=TwoWay}"
                                      Width="60"
                                      Margin="0,0,6,6"
                                      Background="Black"
                                      Foreground="White"
                                      Style="{StaticResource DarkTimeComboBoxStyle}">
                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1D2A38" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#101720" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#D8E1EC" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#101720" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#D8E1EC" />
                                </ComboBox.Resources>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StringFormat={}{0:00}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text=":"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,6,6" />
                            <ComboBox ItemsSource="{Binding ReplayMinuteOptions}"
                                      SelectedItem="{Binding ReplaySelectedMinute, Mode=TwoWay}"
                                      Width="60"
                                      Margin="0,0,6,6"
                                      Background="Black"
                                      Foreground="White"
                                      Style="{StaticResource DarkTimeComboBoxStyle}">
                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1D2A38" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#101720" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#D8E1EC" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#101720" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#D8E1EC" />
                                </ComboBox.Resources>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StringFormat={}{0:00}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Content="Load" Command="{Binding LoadReplayCommand}" Padding="8,2" Margin="0,0,6,6" />
                            <Button Content="Step" Command="{Binding ReplayStepCommand}" Padding="8,2" Margin="0,0,6,6" />
                            <Button Content="{Binding ReplayPlayPauseText}" Command="{Binding ReplayPlayPauseCommand}" Padding="8,2" Margin="0,0,6,6" />
                            <Button Content="Live" Command="{Binding ResumeLiveCommand}" Padding="8,2" Margin="0,0,0,6" />
                            <Button Content="Summary" Command="{Binding ReplaySummaryCommand}" Padding="8,2" Margin="6,0,0,6" />
                        </WrapPanel>
                        <TextBlock Text="{Binding ReplayStatusText}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding SessionReviewSummaryText}" TextWrapping="Wrap" Foreground="#D8E1EC" />
                        <TextBlock Text="{Binding SessionReviewPhasesText}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding SessionReviewOiText}" TextWrapping="Wrap" Foreground="White" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding ReplayOutcomeText}" TextWrapping="Wrap" Foreground="{Binding ReplayOutcomeForeground}" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding SessionReviewExportText}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,6,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource PanelStyle}" Margin="0,0,0,14">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="Live Scan" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                        <TextBlock Text="{Binding LiveScanStatusText}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,4,0,0" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding LiveScanHits}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             MouseLeftButtonUp="LiveScanList_MouseLeftButtonUp">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,6" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#101720"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Symbol}"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SignalLabel}"
                                                   Foreground="{Binding SignalForeground}"
                                                   FontWeight="SemiBold"
                                                   Margin="10,0,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="OI Change Momentum" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                    <controls:LineChartControl Height="132" Margin="0,14,0,0" Series="{Binding OiChartSeries}" />
                    <TextBlock Text="{Binding SelectedStrikeChartTitle}" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,16,0,0" />
                    <controls:LineChartControl Height="132" Margin="0,10,0,0" Series="{Binding SelectedStrikeOiChartSeries}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
