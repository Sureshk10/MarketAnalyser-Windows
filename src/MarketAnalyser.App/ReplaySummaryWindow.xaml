<Window x:Class="MarketAnalyser.App.ReplaySummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selected Day Summary"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="PopupButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#172231" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#D8E1EC" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#203040" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#0F141B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="14"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Top"
                    Background="#111A24"
                    Padding="16,12"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown"
                    Cursor="SizeAll">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="TitleText"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="SubtitleText"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="Summary"
                                Click="SummaryModeButton_Click"
                                Style="{StaticResource PopupButtonStyle}"
                                Margin="0,0,8,0" />
                        <Button Content="Full Data"
                                Click="FullDataModeButton_Click"
                                Style="{StaticResource PopupButtonStyle}"
                                Margin="0,0,8,0" />
                        <Button Content="Copy"
                                Click="CopyButton_Click"
                                Style="{StaticResource PopupButtonStyle}"
                                Margin="0,0,8,0" />
                        <Button Content="Close"
                                Click="CloseButton_Click"
                                Style="{StaticResource PopupButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBox x:Name="SummaryBox"
                         Background="#0F141B"
                         BorderBrush="{StaticResource PanelBorderBrush}"
                         BorderThickness="1"
                         Foreground="#D8E1EC"
                         FontFamily="Consolas"
                         FontSize="12"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Padding="12"
                         CaretBrush="Transparent"
                         MinHeight="120" />

                <DataGrid x:Name="SummaryGrid"
                          Grid.Row="1"
                          Margin="0,14,0,0"
                          SelectionMode="Single"
                          SelectionChanged="SummaryGrid_SelectionChanged"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding RowNo}" Width="50" />
                        <DataGridTextColumn Header="Time" Binding="{Binding TimeText}" Width="90" />
                        <DataGridTextColumn Header="Date" Binding="{Binding DateText}" Width="100" />
                        <DataGridTextColumn Header="Signal" Binding="{Binding Signal}" Width="70" />
                        <DataGridTextColumn Header="Strike" Binding="{Binding StrikeText}" Width="90" />
                        <DataGridTextColumn Header="Spot" Binding="{Binding SpotText}" Width="100" />
                        <DataGridTextColumn Header="Entry" Binding="{Binding EntryText}" Width="90" />
                        <DataGridTextColumn Header="SL" Binding="{Binding StopLossText}" Width="90" />
                        <DataGridTextColumn Header="T1" Binding="{Binding TargetText}" Width="90" />
                        <DataGridTextColumn Header="Outcome" Binding="{Binding OutcomeText}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>

                <DataGrid x:Name="TradeSummaryGrid"
                          Grid.Row="1"
                          Margin="0,14,0,0"
                          SelectionMode="Single"
                          SelectionChanged="TradeSummaryGrid_SelectionChanged"
                          AutoGenerateColumns="False"
                          Visibility="Collapsed">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding RowNo}" Width="45" />
                        <DataGridTextColumn Header="Start" Binding="{Binding StartTime}" Width="90" />
                        <DataGridTextColumn Header="Date" Binding="{Binding DateText}" Width="100" />
                        <DataGridTextColumn Header="Signal" Binding="{Binding Signal}" Width="70" />
                        <DataGridTextColumn Header="Strike" Binding="{Binding StrikeText}" Width="90" />
                        <DataGridTextColumn Header="Entry" Binding="{Binding EntryText}" Width="90" />
                        <DataGridTextColumn Header="Exit" Binding="{Binding ExitTime}" Width="90" />
                        <DataGridTextColumn Header="Outcome" Binding="{Binding OutcomeText}" Width="110" />
                        <DataGridTextColumn Header="Best" Binding="{Binding BestExcursionText}" Width="90" />
                        <DataGridTextColumn Header="Best Time" Binding="{Binding BestExcursionTime}" Width="100" />
                        <DataGridTextColumn Header="SL" Binding="{Binding StopLossText}" Width="90" />
                        <DataGridTextColumn Header="T1" Binding="{Binding TargetText}" Width="90" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </DockPanel>
    </Border>
</Window>
