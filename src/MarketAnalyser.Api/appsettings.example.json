{
  "Api": {
    "DatabasePath": "Data/collector.db",
    "RetentionDays": 30,
    "ApiKey": "CHANGE_ME"
  },
  "Collector": {
    "IsEnabled": true,
    "Symbols": [
      "NIFTY"
    ],
    "PollSeconds": 30,
    "MarketHoursOnly": true,
    "MarketOpen": "09:15",
    "MarketClose": "15:30"
  },
